// Prisma Database Schema for Wavo CRM
// Defines relational entities, multi-tenant fields, and indexing policies

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. ENUMS

enum UserRoleName {
  SUPER_ADMIN
  BUSINESS_OWNER
  MANAGER
  SALES_EXECUTIVE
  SUPPORT_EXECUTIVE
  STAFF_USER
}

enum LeadStage {
  NEW
  CONTACTED
  INTERESTED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum ReminderType {
  CALL
  WHATSAPP
  MEETING
  EMAIL
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  RESCHEDULED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum SubscriptionPlanType {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
}

enum TemplateCategory {
  WELCOME
  FOLLOW_UP
  PAYMENT_REMINDER
  APPOINTMENT_REMINDER
  PROMOTIONS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
}

// 2. DATA MODELS

model Business {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(150)
  businessType String?       @map("business_type") @db.VarChar(100)
  address      String?
  logoUrl      String?       @map("logo_url") @db.VarChar(255)
  gstNumber    String?       @unique @map("gst_number") @db.VarChar(15)
  phone        String?       @db.VarChar(20)
  settings     Json          @default("{}")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  
  users        User[]
  customers    Customer[]
  leads        Lead[]
  followUps    FollowUp[]
  tasks        Task[]
  invoices     Invoice[]
  payments     Payment[]
  notifications Notification[]
  subscription Subscription?
  templates    Template[]
  campaigns    Campaign[]
  auditLogs    AuditLog[]

  @@map("businesses")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        UserRoleName @unique
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  slug        String           @unique @db.VarChar(100)
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String?      @unique @db.VarChar(150)
  phoneNumber  String?      @unique @map("phone_number") @db.VarChar(30)
  passwordHash String?      @map("password_hash") @db.VarChar(255)
  googleId     String?      @unique @map("google_id") @db.VarChar(255)
  firstName    String       @map("first_name") @db.VarChar(100)
  lastName     String?      @map("last_name") @db.VarChar(100)
  avatarUrl    String?      @map("avatar_url") @db.VarChar(255)
  businessId   String?      @map("business_id") @db.Uuid
  roleId       String       @map("role_id") @db.Uuid
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  business     Business?    @relation(fields: [businessId], references: [id], onDelete: SetNull)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assignedLeads Lead[]
  assignedTasks Task[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Customer {
  id           String        @id @default(uuid()) @db.Uuid
  businessId   String        @map("business_id") @db.Uuid
  fullName     String        @map("full_name") @db.VarChar(150)
  mobileNumber String        @map("mobile_number") @db.VarChar(30)
  email        String?       @db.VarChar(150)
  address      String?
  company      String?       @db.VarChar(150)
  source       String        @default("Direct") @db.VarChar(100)
  status       String        @default("Active") @db.VarChar(50)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tags         CustomerTag[]
  leads        Lead[]
  followUps    FollowUp[]
  invoices     Invoice[]

  @@unique([businessId, mobileNumber])
  @@index([businessId])
  @@index([mobileNumber, email])
  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  tagName    String   @map("tag_name") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagName])
  @@index([tagName])
  @@map("customer_tags")
}

model Lead {
  id                 String     @id @default(uuid()) @db.Uuid
  businessId         String     @map("business_id") @db.Uuid
  customerId         String     @map("customer_id") @db.Uuid
  title              String     @db.VarChar(200)
  stage              LeadStage  @default(NEW)
  assignedToUserId   String?    @map("assigned_to_user_id") @db.Uuid
  estimatedValue     Decimal    @default(0.00) @map("estimated_value") @db.Decimal(12, 2)
  leadScore          Int?       @map("lead_score")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  business           Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer           Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTo         User?      @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  followUps          FollowUp[]

  @@index([businessId])
  @@index([assignedToUserId])
  @@map("leads")
}

model FollowUp {
  id         String         @id @default(uuid()) @db.Uuid
  businessId String         @map("business_id") @db.Uuid
  leadId     String?        @map("lead_id") @db.Uuid
  customerId String         @map("customer_id") @db.Uuid
  type       ReminderType   @default(CALL)
  scheduledAt DateTime      @map("scheduled_at")
  status     FollowUpStatus @default(PENDING)
  notes      String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lead       Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId, scheduledAt])
  @@map("follow_ups")
}

model Task {
  id               String       @id @default(uuid()) @db.Uuid
  businessId       String       @map("business_id") @db.Uuid
  assignedToUserId String?      @map("assigned_to_user_id") @db.Uuid
  title            String       @db.VarChar(200)
  description      String?
  dueDate          DateTime?    @map("due_date")
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(TODO)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedTo       User?        @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([assignedToUserId, dueDate])
  @@map("tasks")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  businessId    String        @map("business_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  invoiceNumber String        @map("invoice_number") @db.VarChar(100)
  amount        Decimal       @db.Decimal(12, 2)
  tax           Decimal       @default(0.00) @db.Decimal(12, 2)
  dueDate       DateTime      @map("due_date") @db.Date
  status        InvoiceStatus @default(DRAFT)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  payments      Payment[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId, status])
  @@map("invoices")
}

model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  businessId           String        @map("business_id") @db.Uuid
  invoiceId            String        @map("invoice_id") @db.Uuid
  paymentMethod        String        @map("payment_method") @db.VarChar(50)
  transactionReference String?       @map("transaction_reference") @db.VarChar(150)
  amount               Decimal       @db.Decimal(12, 2)
  status               PaymentStatus @default(PENDING)
  receivedAt           DateTime?     @map("received_at")
  createdAt            DateTime      @default(now()) @map("created_at")

  business             Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice              Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  title      String   @db.VarChar(150)
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model Subscription {
  id                    String               @id @default(uuid()) @db.Uuid
  businessId            String               @unique @map("business_id") @db.Uuid
  planType              SubscriptionPlanType @default(FREE) @map("plan_type")
  status                SubscriptionStatus   @default(ACTIVE)
  billingCycleStart     DateTime             @map("billing_cycle_start")
  billingCycleEnd       DateTime             @map("billing_cycle_end")
  stripeSubscriptionId  String?              @map("stripe_subscription_id") @db.VarChar(150)
  createdAt             DateTime             @map("created_at") @default(now())
  updatedAt             DateTime             @map("updated_at") @updatedAt

  business              Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Template {
  id           String           @id @default(uuid()) @db.Uuid
  businessId   String           @map("business_id") @db.Uuid
  name         String           @db.VarChar(100)
  category     TemplateCategory @default(WELCOME)
  bodyText     String           @map("body_text")
  languageCode String           @default("en") @map("language_code") @db.VarChar(10)
  metaStatus   String           @default("APPROVED") @map("meta_status") @db.VarChar(50)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@unique([businessId, name])
  @@map("templates")
}

model Campaign {
  id            String         @id @default(uuid()) @db.Uuid
  businessId    String         @map("business_id") @db.Uuid
  templateId    String?        @map("template_id") @db.Uuid
  name          String         @db.VarChar(150)
  status        CampaignStatus @default(DRAFT)
  scheduledAt   DateTime?      @map("scheduled_at")
  recipientCount Int            @default(0) @map("recipient_count")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template      Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("campaigns")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  businessId    String?  @map("business_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  action        String   @db.VarChar(100)
  targetTable   String   @map("target_table") @db.VarChar(100)
  recordId      String   @map("record_id") @db.Uuid
  payloadBefore Json     @default("{}") @map("payload_before")
  payloadAfter  Json     @default("{}") @map("payload_after")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  createdAt     DateTime @default(now()) @map("created_at")

  business      Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
